# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# test output
/test-results/
.playwright-mcp/*
/playwright-report/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# diagram data (persisted locally)
/data/diagrams/
/data/context/
.playwright-mcp/

# build artifacts
/server/dist/

# test screenshots & reports (generated, not source)
test-*.png
/docs/test-report/*.png
/docs/test-report/
